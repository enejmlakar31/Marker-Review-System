{
  "id": "Test-bt16rl",
  "name": "Marker & Review System",
  "version": "1.0.0",
  "main": "index.html",
  "host": {
    "app": "premierepro",
    "minVersion": "26.0.0"
  },
  "manifestVersion": 5,
  "featureFlags": {
    "enableAlerts": true
  },
  "permissions": {
    "localFileSystem": "fullAccess",
    "clipboard": "readAndWrite"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "markerReviewPanel",
      "panelId": "markerReviewPanel",
      "label": {
        "default": "Marker & Review",
        "en-US": "Marker & Review",
        "sl-SI": "Označevalec & Pregled"
      },
      "minimumSize": {
        "width": 300,
        "height": 400
      },
      "maximumSize": {
        "width": 1200,
        "height": 10000
      },
      "preferredDockedSize": {
        "width": 380,
        "height": 600
      },
      "preferredFloatingSize": {
        "width": 400,
        "height": 650
      },
      "icons": [
        {
          "width": 32,
          "height": 32,
          "path": "icons/icon_D.png",
          "scale": [1, 2],
          "theme": ["dark", "darkest"],
          "species": ["generic"]
        },
        {
          "width": 32,
          "height": 32,
          "path": "icons/icon_N.png",
          "scale": [1, 2],
          "theme": ["lightest", "light"],
          "species": ["generic"]
        }
      ]
    }
  ],
  "icons": [
    {
      "width": 32,
      "height": 32,
      "path": "icons/icon_D.png",
      "scale": [1, 2],
      "theme": ["dark", "darkest"],
      "species": ["generic"]
    },
    {
      "width": 32,
      "height": 32,
      "path": "icons/icon_N.png",
      "scale": [1, 2],
      "theme": ["lightest", "light"],
      "species": ["generic"]
    }
  ]
}
